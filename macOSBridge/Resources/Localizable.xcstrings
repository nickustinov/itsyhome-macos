    "settings.cameras.grid_columns_description" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wie viele Kameras im Panel nebeneinander stehen. Markiere unten eine Kamera mit dem Pfeil-Symbol für volle Breite."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "How many cameras sit side by side in the panel. Mark a camera full width below with the arrows button."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuántas cámaras se colocan una junto a otra en el panel. Marca abajo una cámara a ancho completo con el botón de flechas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nombre de caméras côte à côte dans le panneau. Marquez une caméra en pleine largeur ci-dessous avec le bouton flèches."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quante telecamere stanno affiancate nel pannello. Segna sotto una telecamera a larghezza intera con il pulsante frecce."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "パネルに横に並べるカメラの数です。下の矢印ボタンでカメラを全幅表示にできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "패널에 나란히 배치할 카메라 수입니다. 아래에서 화살표 버튼으로 카메라를 전체 너비로 표시할 수 있습니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ile kamer stoi obok siebie w panelu. Oznacz poniżej kamerę przyciskiem strzałek, aby zajmowała pełną szerokość."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quantas câmeras ficam lado a lado no painel. Marque abaixo uma câmera em largura total com o botão de setas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сколько камер располагается рядом в панели. Отметьте камеру кнопкой со стрелками ниже, чтобы она занимала всю ширину."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "面板中并排显示的摄像头数量。使用下方的箭头按钮可将摄像头设为全宽。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
