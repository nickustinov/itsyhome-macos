        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Publica sensores virtuales en Apple Home a través de HomeKit. Las habitaciones se asignan en Apple Home tras el emparejamiento."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
