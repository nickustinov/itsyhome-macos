    "onboarding.areas_description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Geräte werden automatisch nach Bereich organisiert. Jeder Bereich erscheint als Raum-Untermenü in Itsyhome."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Your devices are automatically organized by area. Each area appears as a room submenu in Itsyhome."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus dispositivos se organizan automáticamente por área. Cada área aparece como un submenú en Itsyhome."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vos appareils sont organisés automatiquement par zone. Chaque zone apparaît comme un sous-menu dans Itsyhome."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I tuoi dispositivi sono organizzati automaticamente per area. Ogni area appare come un sottomenu stanza in Itsyhome."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デバイスはエリアごとに自動的に整理されます。各エリアはItsyhomeで部屋のサブメニューとして表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기기가 영역별로 자동 정리됩니다. 각 영역은 Itsyhome에서 방 하위 메뉴로 표시됩니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twoje urządzenia są automatycznie pogrupowane według obszaru. Każdy obszar pojawia się jako podmenu pokoju w Itsyhome."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seus dispositivos são organizados automaticamente por área. Cada área aparece como um submenu de cômodo no Itsyhome."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваши устройства автоматически организованы по зонам. Каждая зона отображается как подменю комнаты в Itsyhome."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的设备会按区域自动整理。每个区域在 Itsyhome 中显示为一个房间子菜单。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
