    "settings.networks.permission_denied" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Für den Namen des WLAN-Netzwerks ist der Ortungszugriff nötig. Erteile die Berechtigung unter Systemeinstellungen → Datenschutz & Sicherheit → Ortungsdienste."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Location access is required to read your WiFi network name. Grant permission in System Settings → Privacy & Security → Location Services."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se necesita acceso a la ubicación para leer el nombre de tu red WiFi. Concede el permiso en Ajustes del Sistema → Privacidad y seguridad → Localización."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accès à la localisation est requis pour lire le nom de votre réseau WiFi. Accordez l'autorisation dans Réglages Système → Confidentialité et sécurité → Service de localisation."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accesso alla posizione è necessario per leggere il nome della rete WiFi. Concedi l'autorizzazione in Impostazioni di Sistema → Privacy e sicurezza → Localizzazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WiFiネットワーク名の取得には位置情報へのアクセスが必要です。システム設定→プライバシーとセキュリティ→位置情報サービスで許可してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WiFi 네트워크 이름을 읽으려면 위치 접근 권한이 필요합니다. 시스템 설정 → 개인정보 보호 및 보안 → 위치 서비스에서 권한을 허용하세요."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do odczytania nazwy sieci WiFi wymagany jest dostęp do lokalizacji. Udziel uprawnienia w Ustawieniach systemowych → Prywatność i ochrona → Usługi lokalizacji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O acesso à localização é necessário para ler o nome da sua rede WiFi. Conceda a permissão em Ajustes do Sistema → Privacidade e Segurança → Serviços de Localização."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Для чтения имени сети WiFi требуется доступ к геолокации. Разрешите его в Системных настройках → Конфиденциальность и безопасность → Службы геолокации."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "读取WiFi网络名称需要位置权限。请在系统设置→隐私与安全性→定位服务中授予权限。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "讀取WiFi網路名稱需要位置權限。請在系統設定→隱私權與安全性→定位服務中授予權限。"
          }
        }
      }
    },
