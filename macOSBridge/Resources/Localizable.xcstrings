          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HomeKit経由で仮想センサーをApple Homeに公開します。部屋はペアリング後にApple Homeで割り当てます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HomeKit을 통해 가상 센서를 Apple Home에 게시합니다. 방은 페어링 후 Apple Home에서 지정합니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Publikuje wirtualne czujniki w Apple Home przez HomeKit. Pokoje przypisuje się w Apple Home po sparowaniu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Publica sensores virtuais no Apple Home via HomeKit. Os cômodos são atribuídos no Apple Home após o pareamento."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Публикует виртуальные датчики в Apple Home через HomeKit. Комнаты назначаются в Apple Home после сопряжения."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
