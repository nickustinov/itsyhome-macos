    "settings.automations.form.repulse_note" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple-Home-Automationen reagieren auf Änderungen, nicht auf gehaltene Zustände. Re-Pulse löst den Sensor in diesem Intervall erneut aus, solange er aktiv ist, damit auch zeit- oder anwesenheitsabhängige Automationen ihn erfassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Apple Home automations fire on a change, not a held state. Re-pulse re-fires the sensor on this interval while it's active, so a time- or presence-gated automation can still catch it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las automatizaciones de Apple Home se activan con un cambio, no con un estado mantenido. El repulso vuelve a activar el sensor en este intervalo mientras está activo, para que una automatización condicionada por hora o presencia aún pueda captarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les automatisations Apple Home se déclenchent sur un changement, pas sur un état maintenu. La réimpulsion redéclenche le capteur à cet intervalle tant qu'il est actif, pour qu'une automatisation conditionnée par l'heure ou la présence puisse quand même le capter."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le automazioni di Apple Home si attivano su un cambiamento, non su uno stato mantenuto. Il re-impulso riattiva il sensore a questo intervallo finché è attivo, così un'automazione vincolata a orario o presenza può comunque coglierlo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Homeのオートメーションは状態の保持ではなく変化で発火します。再パルスはセンサーが有効な間この間隔で再発火させ、時刻や在宅条件付きのオートメーションでも捉えられるようにします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Home 자동화는 유지된 상태가 아닌 변화에 반응합니다. 재펄스는 센서가 활성화된 동안 이 간격으로 다시 실행하여 시간이나 재실 조건이 있는 자동화도 이를 포착할 수 있게 합니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatyzacje Apple Home reagują na zmianę, a nie na utrzymywany stan. Ponowny puls wyzwala czujnik ponownie w tym odstępie, dopóki jest aktywny, dzięki czemu automatyzacja zależna od pory dnia lub obecności też go wychwyci."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As automações do Apple Home disparam com uma mudança, não com um estado mantido. O repulso reativa o sensor neste intervalo enquanto estiver ativo, para que uma automação condicionada a horário ou presença ainda possa captá-lo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Автоматизации Apple Home срабатывают на изменение, а не на удерживаемое состояние. Повторный импульс заново активирует датчик с этим интервалом, пока он активен, чтобы автоматизация с условием времени или присутствия всё же его поймала."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "家庭App的自动化在状态变化时触发，而不是持续状态。重复触发会在传感器激活期间按此间隔重新触发，使受时间或在家条件限制的自动化也能捕捉到它。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "家庭App的自動化在狀態變化時觸發，而不是持續狀態。重複觸發會在感應器啟用期間按此間隔重新觸發，使受時間或在家條件限制的自動化也能捕捉到它。"
          }
        }
      }
    },
