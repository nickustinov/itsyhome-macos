    "settings.accessories.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwalte dein Home-Menü von hier. Markiere Geräte als Favoriten, nutze das Auge-Symbol zum Ausblenden von Bereichen oder Geräten, und hefte Elemente an die Menüleiste."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Manage your Home menu from here. Star accessories to add them to Favourites, use the eye icon to hide sections or devices, and pin items to the menu bar."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Administra tu menú de Inicio desde aquí. Marca accesorios como favoritos, usa el icono del ojo para ocultar secciones o dispositivos, y fija elementos a la barra de menús."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gérez votre menu Accueil ici. Marquez des accessoires comme favoris, utilisez l'icône œil pour masquer des sections ou appareils, et épinglez des éléments à la barre de menus."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gestisci il tuo menu Casa da qui. Segna gli accessori come preferiti, usa l'icona occhio per nascondere sezioni o dispositivi, e fissa elementi alla barra dei menu."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ここからホームメニューを管理できます。アクセサリをお気に入りに追加、目のアイコンでセクションやデバイスを非表示、メニューバーにピン留めできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여기에서 홈 메뉴를 관리하세요. 액세서리를 즐겨찾기에 추가하고, 눈 아이콘으로 섹션이나 기기를 숨기고, 메뉴 막대에 고정하세요."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zarządzaj swoim menu Dom stąd. Oznaczaj akcesoria jako ulubione, użyj ikony oka, aby ukryć sekcje lub urządzenia, i przypnij elementy do paska menu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gerencie seu menu Início daqui. Marque acessórios como favoritos, use o ícone de olho para ocultar seções ou dispositivos, e fixe itens na barra de menus."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Управляйте меню Дом отсюда. Отмечайте устройства как избранные, используйте значок глаза, чтобы скрыть разделы или устройства, и закрепляйте элементы в строке меню."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在此管理您的家庭菜单。将配件加入收藏夹，用眼睛图标隐藏分区或设备，将项目固定到菜单栏。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在此管理您的家庭選單。將配件加入喜好項目，用眼睛圖示隱藏區段或裝置，將項目釘選到選單列。"
          }
        }
      }
    },
