    "settings.itsytv.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine kostenlose Begleit-App zur Steuerung von Apple TV über die Menüleiste. Komplette Fernbedienung, Wiedergabe-Widget, App-Launcher und Tastenkürzel – alles nativ auf macOS."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "A free companion app for controlling Apple TV from your Mac menu bar. Full remote control, now playing widget, app launcher, and keyboard shortcuts – all running natively on macOS."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una app gratuita para controlar Apple TV desde la barra de menús. Control remoto completo, widget de reproducción, lanzador de apps y atajos de teclado – todo nativo en macOS."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une app gratuite pour contrôler Apple TV depuis la barre de menus de votre Mac. Télécommande complète, widget en lecture, lanceur d'apps et raccourcis clavier – le tout nativement sur macOS."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un'app gratuita per controllare Apple TV dalla barra dei menu del Mac. Telecomando completo, widget in riproduzione, launcher app e scorciatoie da tastiera – tutto nativo su macOS."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MacのメニューバーからApple TVを操作できる無料アプリ。フルリモコン、再生中ウィジェット、アプリランチャー、キーボードショートカット – すべてmacOSネイティブ。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mac 메뉴 막대에서 Apple TV를 제어하는 무료 앱. 전체 리모컨, 재생 중 위젯, 앱 런처, 키보드 단축키 – 모두 macOS 네이티브."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Darmowa aplikacja do sterowania Apple TV z paska menu Maca. Pełny pilot, widget odtwarzania, launcher aplikacji i skróty klawiszowe – wszystko natywnie na macOS."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um app gratuito para controlar Apple TV pela barra de menus do Mac. Controle remoto completo, widget de reprodução, lançador de apps e atalhos de teclado – tudo nativo no macOS."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Бесплатное приложение для управления Apple TV из строки меню Mac. Полный пульт, виджет воспроизведения, запуск приложений и горячие клавиши – всё нативно на macOS."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一款免费应用，可通过 Mac 菜单栏控制 Apple TV。完整遥控器、正在播放小组件、应用启动器和键盘快捷键 – 全部原生运行于 macOS。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一款免費應用程式，可透過 Mac 選單列控制 Apple TV。完整遙控器、正在播放小工具、應用程式啟動器和鍵盤快速鍵 – 全部原生運行於 macOS。"
          }
        }
      }
    },
