    "settings.homekit_bridge.reset_alert.message" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies entkoppelt die Bridge und erzeugt einen neuen Einrichtungscode. Entferne „Itsyhome Bridge“ aus der Apple-Home-App und füge sie mit dem neuen Code erneut hinzu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "This unpairs the bridge and generates a new setup code. Remove \"Itsyhome Bridge\" from the Apple Home app, then add it again with the new code."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto desempareja el puente y genera un nuevo código de configuración. Elimina \"Itsyhome Bridge\" de la app Casa y vuelve a añadirlo con el nuevo código."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela déjumelle le pont et génère un nouveau code de configuration. Supprimez « Itsyhome Bridge » de l'app Maison, puis ajoutez-le à nouveau avec le nouveau code."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo disaccoppia il bridge e genera un nuovo codice di configurazione. Rimuovi \"Itsyhome Bridge\" dall'app Casa e aggiungilo di nuovo con il nuovo codice."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ブリッジのペアリングを解除し、新しいセットアップコードを生成します。Apple Homeアプリから「Itsyhome Bridge」を削除し、新しいコードで再度追加してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "브리지의 페어링을 해제하고 새 설정 코드를 생성합니다. Apple Home 앱에서 \"Itsyhome Bridge\"를 제거한 후 새 코드로 다시 추가하세요."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To rozłącza mostek i generuje nowy kod konfiguracji. Usuń \"Itsyhome Bridge\" z aplikacji Apple Home, a następnie dodaj go ponownie z nowym kodem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isso despareia a ponte e gera um novo código de configuração. Remova \"Itsyhome Bridge\" do app Casa e adicione novamente com o novo código."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это разорвёт сопряжение моста и создаст новый код настройки. Удалите \"Itsyhome Bridge\" из приложения «Дом», затем добавьте его снова с новым кодом."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将取消桥接器的配对并生成新的设置代码。请从家庭App中移除“Itsyhome Bridge”，然后使用新代码重新添加。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這將取消橋接器的配對並產生新的設定代碼。請從家庭App中移除「Itsyhome Bridge」，然後使用新代碼重新加入。"
          }
        }
      }
    },
