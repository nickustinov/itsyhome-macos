        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\"을(를) 삭제하시겠습니까? 이 작업은 되돌릴 수 없습니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Czy na pewno chcesz usunąć \"%@\"? Tego nie można cofnąć."
