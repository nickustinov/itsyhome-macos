    "settings.advanced.auto_groups_subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fasst ähnliche Geräte zusammen (Alle Lichter, Alle Rollos, ...) für Ein-Klick-Steuerung, im Menü und in jedem Raum."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Group similar devices (All lights, All blinds, ...) for one-click control, in the menu and in each room."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agrupa dispositivos similares (Todas las luces, Todas las persianas, ...) para controlarlos con un clic, en el menú y en cada habitación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regroupe les appareils similaires (Toutes les lumières, Tous les stores, ...) pour un contrôle en un clic, dans le menu et dans chaque pièce."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Raggruppa dispositivi simili (Tutte le luci, Tutte le tapparelle, ...) per il controllo con un clic, nel menu e in ogni stanza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "似たデバイスをまとめて（すべての照明、すべてのブラインドなど）、メニューと各部屋でワンクリック操作できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "비슷한 기기를 묶어(모든 조명, 모든 블라인드 등) 메뉴와 각 방에서 한 번의 클릭으로 제어합니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Grupuje podobne urządzenia (Wszystkie światła, Wszystkie rolety, ...) do sterowania jednym kliknięciem, w menu i w każdym pokoju."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agrupa dispositivos semelhantes (Todas as luzes, Todas as persianas, ...) para controle com um clique, no menu e em cada cômodo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Объединяет похожие устройства (Весь свет, Все шторы, ...) для управления одним кликом – в меню и в каждой комнате."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将相似设备分组（所有灯、所有窗帘等），在菜单和每个房间中一键控制。"
