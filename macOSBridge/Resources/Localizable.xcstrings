    "alert.error.local_network_denied" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Itsyhome benötigt Zugriff auf das lokale Netzwerk, um Home Assistant zu erreichen. Aktiviere ihn in Systemeinstellungen → Datenschutz & Sicherheit → Lokales Netzwerk."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Itsyhome needs local network access to reach Home Assistant. Enable it in System Settings → Privacy & Security → Local Network."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Itsyhome necesita acceso a la red local para conectarse a Home Assistant. Actívalo en Ajustes del Sistema → Privacidad y seguridad → Red local."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Itsyhome a besoin d'accéder au réseau local pour joindre Home Assistant. Activez-le dans Réglages Système → Confidentialité et sécurité → Réseau local."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Itsyhome necessita dell'accesso alla rete locale per raggiungere Home Assistant. Abilitalo in Impostazioni di Sistema → Privacy e sicurezza → Rete locale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ItsyhomeがHome Assistantに接続するには、ローカルネットワークへのアクセスが必要です。システム設定→プライバシーとセキュリティ→ローカルネットワークで有効にしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Itsyhome이 Home Assistant에 연결하려면 로컬 네트워크 접근이 필요합니다. 시스템 설정 → 개인정보 보호 및 보안 → 로컬 네트워크에서 활성화하세요."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Itsyhome potrzebuje dostępu do sieci lokalnej, aby połączyć się z Home Assistant. Włącz go w Ustawienia systemowe → Prywatność i ochrona → Sieć lokalna."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Itsyhome precisa de acesso à rede local para se conectar ao Home Assistant. Ative em Ajustes do Sistema → Privacidade e Segurança → Rede Local."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Itsyhome требуется доступ к локальной сети для подключения к Home Assistant. Включите его в Системных настройках → Конфиденциальность и безопасность → Локальная сеть."
          }
        },
        "zh-Hans" : {
