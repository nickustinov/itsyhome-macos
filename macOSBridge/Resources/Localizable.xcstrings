    "alert.delete_group.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Möchtest du \"%@\" wirklich löschen? Dies kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Are you sure you want to delete \\\"%@\\\"? This cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Seguro que quieres eliminar \"%@\"? No se puede deshacer."
