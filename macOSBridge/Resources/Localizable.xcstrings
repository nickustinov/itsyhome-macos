    "settings.itsyhome_ios.description" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Itsyhome gibt es auch für iPhone und iPad – in deinem Pro-Kauf enthalten. Steuere dein HomeKit-Zuhause von überall, mit demselben schnellen nativen Erlebnis."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Itsyhome is also available for iPhone and iPad – included with your Pro purchase. Control your HomeKit setup from anywhere, with the same fast native experience."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Itsyhome también está disponible para iPhone y iPad, incluido con tu compra de Pro. Controla tu HomeKit desde cualquier lugar, con la misma experiencia nativa y rápida."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Itsyhome existe aussi pour iPhone et iPad – inclus avec votre achat Pro. Contrôlez votre HomeKit où que vous soyez, avec la même expérience native et rapide."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Itsyhome è disponibile anche per iPhone e iPad – incluso nel tuo acquisto Pro. Controlla il tuo HomeKit ovunque, con la stessa esperienza nativa e veloce."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ItsyhomeはiPhoneとiPadでも利用できます – Pro購入に含まれています。同じ高速なネイティブ体験で、どこからでもHomeKitをコントロールできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Itsyhome은 iPhone과 iPad에서도 사용할 수 있으며 Pro 구매에 포함되어 있습니다. 어디서나 동일하게 빠른 네이티브 경험으로 HomeKit을 제어하세요."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Itsyhome jest dostępny także na iPhone'a i iPada – w ramach zakupu Pro. Steruj swoim HomeKit z dowolnego miejsca, z tym samym szybkim natywnym działaniem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Itsyhome também está disponível para iPhone e iPad – incluído na sua compra do Pro. Controle seu HomeKit de qualquer lugar, com a mesma experiência nativa e rápida."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Itsyhome доступен также для iPhone и iPad – входит в покупку Pro. Управляйте своим HomeKit откуда угодно с тем же быстрым нативным интерфейсом."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Itsyhome也有iPhone和iPad版 – 已包含在您的Pro购买中。随时随地控制您的HomeKit，享受同样快速的原生体验。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Itsyhome也有iPhone和iPad版 – 已包含在您的Pro購買中。隨時隨地控制您的HomeKit，享受同樣快速的原生體驗。"
          }
        }
      }
    },
