    "settings.homekit_bridge.description" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Virtuelle Sensoren über HomeKit an Apple Home veröffentlichen. Räume werden nach dem Koppeln in Apple Home zugewiesen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Publish virtual sensors to Apple Home over HomeKit. Rooms are assigned in Apple Home after pairing."
          }
