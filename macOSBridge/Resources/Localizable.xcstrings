    "settings.automations.form.action_note" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Setzt %1$@ auf %2$@, solange der Auslöser aktiv ist, danach zurück auf %3$@."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Sets %1$@ to %2$@ while the trigger holds, then back to %3$@ when it clears."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Establece %1$@ en %2$@ mientras el disparador se mantiene, y vuelve a %3$@ cuando cesa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Définit %1$@ sur %2$@ tant que le déclencheur est actif, puis revient à %3$@ quand il cesse."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imposta %1$@ su %2$@ finché il trigger è attivo, poi torna a %3$@ quando termina."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "トリガーが続く間は%1$@を%2$@に設定し、解除されると%3$@に戻します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "트리거가 유지되는 동안 %1$@을(를) %2$@(으)로 설정하고, 해제되면 %3$@(으)로 되돌립니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ustawia %1$@ na %2$@, dopóki wyzwalacz trwa, a po jego ustaniu wraca do %3$@."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Define %1$@ como %2$@ enquanto o gatilho durar e volta para %3$@ quando ele cessar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Устанавливает %1$@ в %2$@, пока действует триггер, затем возвращает в %3$@."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "触发条件保持期间将%1$@设为%2$@，条件解除后恢复为%3$@。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "觸發條件保持期間將%1$@設為%2$@，條件解除後恢復為%3$@。"
          }
        }
      }
    },
