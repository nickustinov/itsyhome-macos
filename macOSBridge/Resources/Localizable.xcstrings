    "settings.automations.description" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automationen beobachten ein HomeKit-Gerät und setzen einen virtuellen Sensor, wenn es einen Zustand für eine Dauer hält (mit Re-Pulse) – so kann Apple Home auf Bedingungen automatisieren, die HomeKit selbst nicht berechnen kann, z. B. „15 Minuten offen“."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Automations watch a HomeKit accessory and, when it holds a state for a duration, set a virtual sensor (re-pulsing it) - so Apple Home can automate on conditions HomeKit can't compute itself, like \"open for 15 minutes\"."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las automatizaciones observan un accesorio de HomeKit y, cuando mantiene un estado durante un tiempo, activan un sensor virtual (repulsándolo), para que Apple Home pueda automatizar condiciones que HomeKit no puede calcular por sí mismo, como \"abierto durante 15 minutos\"."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les automatisations surveillent un accessoire HomeKit et, quand il conserve un état pendant une durée, définissent un capteur virtuel (avec réimpulsion) – Apple Home peut ainsi automatiser des conditions que HomeKit ne sait pas calculer lui-même, comme « ouvert depuis 15 minutes »."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le automazioni osservano un accessorio HomeKit e, quando mantiene uno stato per una durata, impostano un sensore virtuale (con re-impulso) – così Apple Home può automatizzare condizioni che HomeKit non sa calcolare da solo, come \"aperto da 15 minuti\"."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "オートメーションはHomeKitアクセサリを監視し、状態が一定時間続くと仮想センサーを設定（再パルス）します。「15分間開いたまま」など、HomeKit自身では計算できない条件でApple Homeを自動化できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "자동화는 HomeKit 액세서리를 관찰하다가 상태가 일정 시간 유지되면 가상 센서를 설정(재펄스)합니다. \"15분 동안 열려 있음\"처럼 HomeKit이 자체적으로 계산할 수 없는 조건으로 Apple Home을 자동화할 수 있습니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatyzacje obserwują akcesorium HomeKit i gdy utrzymuje ono stan przez określony czas, ustawiają wirtualny czujnik (z ponownym pulsowaniem) – dzięki temu Apple Home może automatyzować warunki, których HomeKit sam nie potrafi obliczyć, np. \"otwarte przez 15 minut\"."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As automações observam um acessório HomeKit e, quando ele mantém um estado por um período, definem um sensor virtual (com repulso) – assim o Apple Home pode automatizar condições que o HomeKit não consegue calcular sozinho, como \"aberto por 15 minutos\"."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Автоматизации следят за аксессуаром HomeKit и, когда он удерживает состояние заданное время, устанавливают виртуальный датчик (с повторным импульсом) – так Apple Home может автоматизировать условия, которые HomeKit сам вычислить не может, например \"открыто 15 минут\"."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自动化会监视HomeKit配件，当其保持某状态达到设定时长时设置虚拟传感器（并重复触发），让家庭App能对HomeKit自身无法计算的条件进行自动化，例如“打开15分钟”。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自動化會監視HomeKit配件，當其保持某狀態達到設定時長時設定虛擬感應器（並重複觸發），讓家庭App能對HomeKit自身無法計算的條件進行自動化，例如「打開15分鐘」。"
          }
        }
      }
    },
